# NexAI / Sol local development environment example.
# Copy to .env only for local use. Do not commit real secrets.

# API bind settings
SOL_API_HOST=127.0.0.1
SOL_API_PORT=8420

# Local/demo installs normally run without login.
SOL_AUTH_ENABLED=false
SOL_AUTH_USER=nexus
SOL_AUTH_PASSWORD=
SOL_AUTH_PASSWORD_SHA256=

# OpenAI-compatible provider. Leave empty unless using OpenAI.
SOL_OPENAI_API_KEY=
SOL_OPENAI_MODEL=gpt-4o-mini
SOL_OPENAI_BASE_URL=https://api.openai.com

# Local Ollama provider.
SOL_OLLAMA_BASE_URL=http://127.0.0.1:11434
SOL_OLLAMA_REQUEST_TIMEOUT_S=60

# RAG defaults.
SOL_RAG_ENABLED=true
SOL_RAG_ALLOWED_ROOTS=

# Filesystem and web access are disabled by default for API-level tool paths.
SOL_FS_ENABLED=false
SOL_FS_ALLOWED_ROOTS=
SOL_FS_WRITE_ENABLED=false
SOL_FS_DELETE_ENABLED=false
SOL_WEB_ENABLED=false
SOL_WEB_ALLOWED_HOSTS=
